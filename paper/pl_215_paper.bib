@article{silvia2018,
  title = {Municipal Reaction to Functional Rescaling in {{Italy}}},
  author = {Silvia, Bolgherini and Mattia, Casula and Mariano, Marotta},
  date = {2018},
  journaltitle = {The International Journal of Public Sector Management},
  volume = {31},

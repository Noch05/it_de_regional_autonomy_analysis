  publisher = {[GENES, ADRES]},
  issn = {0019-0209},
  doi = {10.2307/20075301},
  url = {https://www.jstor.org/stable/20075301},
  urldate = {2025-11-10},
  abstract = {When variable individual coefficients are considered random, the generalized least squares estimator of their expectation can be viewed as a matrix weighted combination of between and within estimators. Such an estimator is biased, however, when correlation exists between the individual coefficients and the explanatory variables. Introducing such dependence in a form of an auxiliary regression, it is possible to devise a GLS estimator which is consistent provided that the number of individuals goes to infinity. Various other problems pertaining to variances estimation are also considered. /// Ce texte traite des problèmes que soulève, dans les modèles sur données individuelles temporelles, la présence de coefficients variables, et plus particulièrement de coefficients individuels aléatoires. Après avoir indiqué l'expression des estimateurs des moindres carrés généralisés ainsi que diverses interprétations de ceux-ci, on montre que ces estimateurs sont biaisés si les coefficients individuels ne sont pas indépendants des variables explicatives elles-mêmes. Représentant de telles liaisons par des réqressions linéaires, on peut à nouveau, par une procédure de moindres carrés généralisés, construire des estimateurs convergents et efficaces. /// Eos problemas planteados en los modelos sobre datos individuales temporales por la presencia de coeficientes variables, y en especial de coeficientes individuales aleatorios, estan examinados en este artículo. Tras indicar la expresión de los estimadores de mínimos cuadrados generalizados así como diversas interpretaciones de estos, se pone de manifiesto que estos estimadores presentan inclinaciones viciadas si los coeficientes no son independientes de la smismas variables explicativas. Representando tales vínculos por regresiones lineares, es factible edificar de nuevo estimadores convergentes y eficientes mediante un proceso de mínimos cuadrados generalizados.},
  file = {C:\Users\noaho\Zotero\storage\TICWPFKP\Mundlak - 1978 - Models with Variable Coefficients Integration and Extension.pdf}
}

@article{neuhaus1998,
  title = {Between- and within-Cluster Covariate Effects in the Analysis of Clustered Data},
  author = {Neuhaus, J. M. and Kalbfleisch, J. D.},
  date = {1998-06},
  journaltitle = {Biometrics},
  shortjournal = {Biometrics},
  volume = {54},
  number = {2},
  eprint = {9629647},
  eprinttype = {pubmed},
  pages = {638--645},
  issn = {0006-341X},
  abstract = {Standard methods for the regression analysis of clustered data postulate models relating covariates to the response without regard to between- and within-cluster covariate effects. Implicit in these analyses is the assumption that these effects are identical. Example data show that this is frequently not the case and that analyses that ignore differential between- and within-cluster covariate effects can be misleading. Consideration of between- and within-cluster effects also helps to explain observed and theoretical differences between mixture model analyses and those based on conditional likelihood methods. In particular, we show that conditional likelihood methods estimate purely within-cluster covariate effects, whereas mixture model approaches estimate a weighted average of between- and within-cluster covariate effects.},
  langid = {english},
  keywords = {Adolescent,Analysis of Variance,Biometry,Birth Weight,Body Weight,Child,Cluster Analysis,Georgia,Humans,Infant Newborn,Likelihood Functions,Models Statistical,Regression Analysis}
}

